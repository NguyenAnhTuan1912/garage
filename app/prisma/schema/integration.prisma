model ServiceProvider {
    id        String    @id @default(uuid())
    name      String    @unique
    // Joined fields
    user      User?     @relation(fields: [createdBy], references: [id])
    services  Service[]
    // Audit fields
    createdAt DateTime  @default(now())
    createdBy String
    updatedAt DateTime?
    updatedBy String?
    deletedAt DateTime?
    deletedBy String?

    @@map("service_provider")
}

model Service {
    id           String          @id @default(uuid())
    providerId   String
    name         String          @unique
    dataTemplate Json
    // Joined fields
    user         User?           @relation(fields: [createdBy], references: [id])
    provider     ServiceProvider @relation(fields: [providerId], references: [id])
    integrations Integration[]
    // Audit fields
    createdAt    DateTime        @default(now())
    createdBy    String
    updatedAt    DateTime?
    updatedBy    String?
    deletedAt    DateTime?
    deletedBy    String?

    @@map("service")
}

model Integration {
    id        String    @id @default(uuid())
    serviceId String
    data      Json
    // Joined fields
    user      User?     @relation(fields: [createdBy], references: [id])
    service   Service   @relation(fields: [serviceId], references: [id])
    // Audit fields
    createdAt DateTime  @default(now())
    createdBy String
    updatedAt DateTime?
    updatedBy String?
    deletedAt DateTime?
    deletedBy String?

    @@map("integration")
}
