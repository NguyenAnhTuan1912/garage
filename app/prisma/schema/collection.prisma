enum CollectionType {
    LINK
    WORD_EXPLANATION
}

model Collection {
    id          String         @id @default(uuid())
    type        CollectionType @default(LINK)
    title       String
    description String?
    topic       String?
    photo       String?
    // Joined fields
    owner       User           @relation("CollectionCreator", fields: [createdBy], references: [id])
    items       Item[]         @relation("CollectionItems")
    // Audit fields
    createdAt   DateTime       @default(now())
    createdBy   String
    updatedAt   DateTime?
    updatedBy   String?
    deletedAt   DateTime?
    deletedBy   String?
    // Unsupported fields (features)
    tsv_search  Unsupported("tsvector")?

    @@index([type])
    @@index([topic])
    @@map("collection")
    @@index([tsv_search], type: Gin, name: "idx_collection_search")
}

model Item {
    id           String         @id @default(uuid())
    collectionId String
    type         CollectionType @default(LINK)
    description  String?
    content      String
    // Joined fields
    owner        User           @relation("ItemCreator", fields: [createdBy], references: [id])
    collection   Collection     @relation("CollectionItems", fields: [collectionId], references: [id])
    // Audit fields
    createdAt    DateTime       @default(now())
    createdBy    String
    updatedAt    DateTime?
    updatedBy    String?
    deletedAt    DateTime?
    deletedBy    String?

    @@index([type])
    @@map("item")
}
