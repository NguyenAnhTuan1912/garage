model Note {
    id        String    @id @default(uuid())
    userId    String?
    parentId  String?
    title     String    @default(dbgenerated("'Untitled Note ' || now()::text"))
    content   String
    topic     String?
    // Joined fields
    author    User      @relation("NoteCreator", fields: [createdBy], references: [id])
    parent    Note?     @relation("NoteToSubnotes", fields: [parentId], references: [id])
    children  Note[]    @relation("NoteToSubnotes")
    // Audit fields
    createdAt DateTime  @default(now())
    createdBy String
    updatedAt DateTime?
    updatedBy String?
    deletedAt DateTime?
    deletedBy String?
    // Unsupported fields (features)
    tsv_search  Unsupported("tsvector")?

    @@map("note")
    @@index([tsv_search], type: Gin, name: "idx_note_search")
}
