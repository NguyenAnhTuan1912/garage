model Note {
    id        String    @id @default(uuid())
    parentId  String?
    title     String    @default(dbgenerated("'Untitled Note ' || now()::text"))
    content   String
    topic     String?
    // Joined fields
    author    User      @relation("NoteCreator", fields: [createdBy], references: [id])
    parent    Note?     @relation("NoteToSubnotes", fields: [parentId], references: [id])
    children  Note[]    @relation("NoteToSubnotes")
    // Audit fields
    createdAt DateTime  @default(now())
    createdBy String
    updatedAt DateTime  @updatedAt
    updatedBy String?
    deletedAt DateTime?
    deletedBy String?
    userId    String?

    @@map("note")
}
